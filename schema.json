    "components": {
        "schemas": {
            "Attendance": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid",
                        "readOnly": true
                    },
                    "working_hours_display": {
                        "type": "string",
                        "readOnly": true
                    },
                    "employee_name": {
                        "type": "string",
                        "readOnly": true
                    },
                    "date": {
                        "type": "string",
                        "format": "date"
                    },
                    "status": {
                        "$ref": "#/components/schemas/StatusEnum"
                    },
                    "clock_in": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "clock_out": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "break_in": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "break_out": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "total_break_minutes": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": 0,
                        "format": "int64"
                    },
                    "total_working_minutes": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": 0,
                        "format": "int64"
                    },
                    "effective_working_minutes": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": 0,
                        "format": "int64"
                    },
                    "overtime_minutes": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": 0,
                        "format": "int64"
                    },
                    "late_minutes": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": 0,
                        "format": "int64"
                    },
                    "early_leaving_minutes": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": 0,
                        "format": "int64"
                    },
                    "clock_in_source": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/ClockInSourceEnum"
                            },
                            {
                                "$ref": "#/components/schemas/BlankEnum"
                            }
                        ]
                    },
                    "clock_out_source": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/ClockOutSourceEnum"
                            },
                            {
                                "$ref": "#/components/schemas/BlankEnum"
                            }
                        ]
                    },
                    "clock_in_latitude": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,3}(?:\\.\\d{0,7})?$",
                        "nullable": true
                    },
                    "clock_in_longitude": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,3}(?:\\.\\d{0,7})?$",
                        "nullable": true
                    },
                    "clock_in_address": {
                        "type": "string"
                    },
                    "clock_in_within_geofence": {
                        "type": "boolean",
                        "nullable": true
                    },
                    "clock_out_latitude": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,3}(?:\\.\\d{0,7})?$",
                        "nullable": true
                    },
                    "clock_out_longitude": {
                        "type": "string",
                        "format": "decimal",
                        "pattern": "^-?\\d{0,3}(?:\\.\\d{0,7})?$",
                        "nullable": true
                    },
                    "clock_out_address": {
                        "type": "string"
                    },
                    "clock_out_within_geofence": {
                        "type": "boolean",
                        "nullable": true
                    },
                    "clock_in_selfie": {
                        "type": "string",
                        "format": "uri",
                        "nullable": true
                    },
                    "clock_out_selfie": {
                        "type": "string",
                        "format": "uri",
                        "nullable": true
                    },
                    "is_wfh": {
                        "type": "boolean"
                    },
                    "wfh_approved": {
                        "type": "boolean"
                    },
                    "remarks": {
                        "type": "string"
                    },
                    "admin_remarks": {
                        "type": "string"
                    },
                    "is_regularized": {
                        "type": "boolean"
                    },
                    "regularized_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "employee": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "regularized_by": {
                        "type": "string",
                        "format": "uuid",
                        "nullable": true
                    },
                    "shift": {
                        "type": "string",
                        "format": "uuid",
                        "nullable": true
                    }
                },
                "required": [
                    "created_at",
                    "date",
                    "employee",
                    "employee_name",
                    "id",
                    "updated_at",
                    "working_hours_display"
                ]
            },
            "BlankEnum": {
                "enum": [
                    ""
                ]
            },
            "ClockInSourceEnum": {
                "enum": [
                    "web",
                    "mobile",
                    "biometric",
                    "qr",
                    "admin",
                    "auto"
                ],
                "type": "string",
                "description": "* `web` - Web\n* `mobile` - Mobile\n* `biometric` - Biometric\n* `qr` - QR Code\n* `admin` - Admin\n* `auto` - Auto"
            },
            "ClockOutSourceEnum": {
                "enum": [
                    "web",
                    "mobile",
                    "biometric",
                    "qr",
                    "admin",
                    "auto"
                ],
                "type": "string",
                "description": "* `web` - Web\n* `mobile` - Mobile\n* `biometric` - Biometric\n* `qr` - QR Code\n* `admin` - Admin\n* `auto` - Auto"
            },
            "PaginatedAttendanceList": {
                "type": "object",
